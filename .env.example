# ── Polymarket API ──────────────────────────────────────────
POLYMARKET_CLOB_WS=wss://ws-subscriptions-clob.polymarket.com/ws/market
POLYMARKET_CLOB_HOST=https://clob.polymarket.com
# Proxy for CLOB API geoblock bypass (NordVPN SOCKS5, use Netherlands/Sweden — NOT US)
# CLOB_PROXY_URL=socks5://user:pass@amsterdam.nl.socks.nordhold.net:1080
GAMMA_API_BASE=https://gamma-api.polymarket.com
GAMMA_API_RATE_LIMIT=4000

# ── Trading credentials ────────────────────────────────────
POLYMARKET_PRIVATE_KEY=
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# ── Redis (optional — bot degrades to DB/API fallback) ─────
REDIS_URL=redis://localhost:6379/1

# ── DuckDB ─────────────────────────────────────────────────
DUCKDB_PATH=./data/polymarket.duckdb

# ── Dashboard ──────────────────────────────────────────────
DASHBOARD_PORT=8083
DASHBOARD_HOST=0.0.0.0
DASHBOARD_TOKEN=

# ── Alerts ─────────────────────────────────────────────────
ALERT_ENABLED=true
IMSG_HANDLE=

# ── Logging ────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=./logs/polymarket-bot.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# ── Bond strategy ──────────────────────────────────────────
BOND_ENABLED=false
BOND_SEED_CAPITAL=300
BOND_SCAN_INTERVAL=300
BOND_MIN_VOLUME=250000
BOND_MIN_LIQUIDITY=1000
BOND_MIN_SCORE=0.01

# ── Bond sizing (Kelly / scoring) ──────────────────────────
BOND_KELLY_PRIOR_ALPHA=50.0
BOND_KELLY_PRIOR_BETA=1.0
BOND_EXECUTION_DEGRADATION=0.02
BOND_LIQUIDITY_SCALE=5000
BOND_TIME_TAU=14.0
BOND_TIME_TAU_SIZING=30.0
BOND_VOLUME_SCALE=5000000
BOND_YIELD_SCALE=2.0
BOND_CONC_SIGMA=0.50
BOND_DIV_DECAY=3.0

# ── Bond risk controls ─────────────────────────────────────
BOND_MAX_ORDER_PCT=0.25
BOND_ORDER_TIMEOUT_HOURS=4
BOND_AUTO_EXIT_SEVERITY=0.10
BOND_AUTO_EXIT_SEVERITY_TIGHT=0.05
BOND_EXIT_ESCALATION_SECS=120
BOND_HALT_DRAWDOWN_PCT=0.20
BOND_COOLDOWN_TAU=3600
BOND_MAX_CATEGORY_PCT=0.40
BOND_MAX_DAILY_ORDERS=20
BOND_MAX_DAILY_CAPITAL_PCT=0.80
BOND_ADAPTIVE_PRICING=true
BOND_PRICE_IMPROVE_SECS=60
BOND_MAX_REST_FETCHES=50
BOND_OB_MAX_AGE=300

# ── Drawdown-constrained Kelly ─────────────────────────────
DRAWDOWN_MAX=0.30
DRAWDOWN_EPSILON=0.05

# ── Domain watchlist ───────────────────────────────────────
DOMAIN_WATCH_ENABLED=true
DOMAIN_EWMA_HALFLIFE=24.0
DOMAIN_ALERT_Z_SCALE=2.0
DOMAIN_VOLUME_SCALE=50000
DOMAIN_ALERT_COOLDOWN_TAU=14400
